{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docket.dev/schemas/backlog-apply-v1.schema.json",
  "title": "Docket Backlog Apply Spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "tickets"],
  "properties": {
    "version": {
      "type": "string",
      "const": "docket.apply/v1"
    },
    "tickets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "ref": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
          },
          "id": {
            "type": "string",
            "pattern": "^TKT-[0-9]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 1
          },
          "state": {
            "type": "string",
            "minLength": 1
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "parent": {
            "type": "string",
            "pattern": "^TKT-[0-9]+$"
          },
          "parent_ref": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_.-]*$"
          },
          "blocked_by": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^(TKT-[0-9]+|[A-Za-z][A-Za-z0-9_.-]*)$"
            }
          },
          "ac": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
