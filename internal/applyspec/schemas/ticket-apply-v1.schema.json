{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docket.dev/schemas/ticket-apply-v1.schema.json",
  "title": "Docket Ticket Apply Spec v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "ticket"],
  "properties": {
    "version": {
      "type": "string",
      "const": "docket.apply/v1"
    },
    "operation": {
      "type": "string",
      "enum": ["create", "update", "upsert"]
    },
    "ticket": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^TKT-[0-9]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "priority": {
          "type": "integer",
          "minimum": 1
        },
        "state": {
          "type": "string",
          "enum": ["backlog", "todo", "in-progress", "in-review", "done", "archived"]
        },
        "labels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "parent": {
          "type": "string",
          "pattern": "^TKT-[0-9]+$"
        },
        "blocked_by": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^TKT-[0-9]+$"
          }
        },
        "ac": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
